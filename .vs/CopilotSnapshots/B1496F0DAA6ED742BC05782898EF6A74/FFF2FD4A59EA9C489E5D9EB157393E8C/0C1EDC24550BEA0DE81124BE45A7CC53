using System;
using System.Collections.Generic;
using System.Data;
using System.Windows.Forms;
using ReadLog.Controllers;
using ReadLog.Forms;

namespace ReadLog.Forms
{
    public partial class DashboardForm : Form
    {
        // 1. Link our middleman controllers
        private BookController _bookController = new BookController();
        private GoalController _goalController = new GoalController();

        public DashboardForm()
        {
            InitializeComponent();
            LoadDashboard();
        }

        private void LoadDashboard()
        {
            try
            {
                // 2. Fetch data updates using Controllers (No SQL text allowed here!)
                int totalRead = _bookController.GetBookCountByStatus("Read");
                int currentReading = _bookController.GetBookCountByStatus("Currently Reading");
                List<string> recentBooks = _bookController.GetRecentBookTitles();
                DataRow latestGoal = _goalController.GetLatestGoalData();

                // 3. UI Display: Update the counts labels
                lblTotalRead.Text = totalRead.ToString();
                lblCurrentlyReading.Text = currentReading.ToString();

                // 4. UI Display: Update the recent books listbox
                lstRecentBooks.Items.Clear();
                foreach (string title in recentBooks)
                {
                    lstRecentBooks.Items.Add(title);
                }

                // 5. UI Display: Process and present Goal values
                if (latestGoal != null)
                {
                    int target = Convert.ToInt32(latestGoal["TargetBooks"]);
                    int completed = Convert.ToInt32(latestGoal["CompletedBooks"]);

                    lblGoal.Text = $"{completed} / {target}";

                    int percent = 0;
                    if (target > 0)
                    {
                        percent = (completed * 100) / target;
                    }

                    if (percent > 100) percent = 100;

                    progressGoal.Value = percent;
                    lblGoalPercent.Text = $"{percent}% complete";
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading dashboard contents: {ex.Message}", "Application Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        // --- NAVIGATION BUTTONS ---
        private void btnLibrary_Click(object sender, EventArgs e)
        {
            LibraryForm libForm = new LibraryForm(this);
            this.Hide();
            libForm.Show();
        }

        private void btnAddBook_Click(object sender, EventArgs e)
        {
            AddEditBookForm form = new AddEditBookForm();
            this.Hide();
            form.Show();
        }

        private void btnReadingGoal_Click(object sender, EventArgs e)
        {
            ReadingGoalForm form = new ReadingGoalForm();
            this.Hide();
            form.Show();
        }

        private void btnLogout_Click(object sender, EventArgs e)
        {
            LoginForm loginForm = new LoginForm();
            loginForm.Show();
            this.Close();
        }
    }
}